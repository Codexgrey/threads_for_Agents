# ─── Database (Supabase / Postgres) ───────────────────────────────
# When unset, the app serves the built-in seed data in-memory so the
# live preview works with zero infra. Set this to enable real persistence.
DATABASE_URL=


# ─── Auth (NextAuth / Auth.js — Google provider) ──────────────────
# Generate a secret with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=


# Google OAuth credentials from https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=


# Set to your deployment URL in production (e.g. https://your-app.vercel.app)
# NEXTAUTH_URL=http://localhost:3000


# ─── Cloudflare R2 (S3-compatible object storage for avatars/media) ─
# Optional. When unset, seeded avatar URLs are used directly.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=


# Public base URL for the bucket (R2 public bucket or custom domain)
R2_PUBLIC_URL=



# ─── Public site URL (used by llms.txt + metadata) ────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
